{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"rootDir": "src",
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node", "jest"],
		"paths": {
			"@chenaikit/core": ["../core/dist/index.d.ts"],
			"@chenaikit/core/*": ["../core/dist/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules"]
}
